# BomFilho backend environment template
# Encoding: UTF-8
# Keep secrets only in Render (or local .env never committed).

# ============================================
# CORE (required)
# ============================================
NODE_ENV=development
PORT=3000
SERVICE_NAME=bom-filho-backend
API_VERSION=1.0.0

# PostgreSQL URL from Render
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
# Set true only when your DB endpoint requires TLS
DB_SSL=false

# Backend public URL (required in production)
BASE_URL=http://localhost:3000
# Frontend public URL (recommended; also added to CORS allow-list)
FRONTEND_APP_URL=http://localhost:5173
# Comma-separated allow list
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Behind trusted reverse proxy (Render/Cloudflare/Nginx)
TRUST_PROXY=false

# ============================================
# AUTH / COOKIE / SECURITY (required in production)
# ============================================
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
COOKIE_SECURE=false
# strict | lax | none
COOKIE_SAME_SITE=strict
COOKIE_DOMAIN=

DIAGNOSTIC_TOKEN=
ALLOW_REMOTE_DIAGNOSTIC=false

METRICS_ENABLED=false
METRICS_TOKEN=

# Keep distributed idempotency enabled unless debugging
DISTRIBUTED_IDEMPOTENCY_ENABLED=true

# ============================================
# ADMIN
# ============================================
ADMIN_USER=admin
# Local/dev fallback only. Do not use plain password in production.
ADMIN_PASSWORD=
# Production-safe admin password (bcrypt hash)
ADMIN_PASSWORD_HASH=
ADMIN_LOCAL_ONLY=true

# ============================================
# MERCADO PAGO (active gateway - required)
# ============================================
# test | production
MP_ENV=test
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=
MP_SUCCESS_URL=
MP_PENDING_URL=
MP_FAILURE_URL=
# Never enable this in production
MP_WEBHOOK_ALLOW_INSECURE_WHEN_SECRET_MISSING=false

# ============================================
# RECAPTCHA
# ============================================
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_AUTH_ENABLED=false
RECAPTCHA_CHECKOUT_ENABLED=false
RECAPTCHA_PAYMENT_ENABLED=false

# ============================================
# DELIVERY / FRETE
# ============================================
PRECO_COMBUSTIVEL_LITRO=6.2
CEP_MERCADO=68740180
NUMERO_MERCADO=70
LIMITE_BIKE_KM=1
FRETE_DEBUG_LOGS=true
TAXA_SERVICO_PERCENTUAL=3

# ============================================
# CACHE / IMPORT / TIMEOUTS
# ============================================
PRODUTOS_QUERY_CACHE_TTL_MS=20000
TAMANHO_MAXIMO_IMPORTACAO_MB=8
IMPORTACAO_TAMANHO_LOTE_INSERCAO=300
IMPORTACAO_TAMANHO_LOTE_ATUALIZACAO=250
IMPORTACAO_TAMANHO_LOTE_PRE_CARGA_CHAVES=1000
ENRICHMENT_JOB_TIMEOUT_MS=7200000

REQUEST_TIMEOUT_PADRAO=20s
REQUEST_TIMEOUT_ADMIN=30s
REQUEST_TIMEOUT_IMPORTACAO=600s
EXTERNAL_HTTP_TIMEOUT_MS=8000
BRASIL_API_TIMEOUT_MS=5000
WHATSAPP_HTTP_TIMEOUT_MS=8000
BARCODE_LEGADO_TIMEOUT_MS=4500

DB_CONNECTION_LIMIT=10
DB_CONNECT_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000

# ============================================
# WHATSAPP / EVOLUTION (optional)
# ============================================
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=loja
EVOLUTION_WEBHOOK_TOKEN=
WHATSAPP_AUTO_REPLY_ENABLED=false
WHATSAPP_AUTO_REPLY_TEXT=Estamos com o site do Bom Filho no ar. Faca seu pedido por la.
WHATSAPP_AUTO_REPLY_COOLDOWN_SECONDS=0

# ============================================
# BARCODE ENRICHMENT (optional)
# ============================================
BARCODE_PROVIDER_ORDER=openfoodfacts,cosmos,upcitemdb
BARCODE_PROVIDER_TIMEOUT_MS=4500
BARCODE_PROVIDER_MAX_RETRIES=1
BARCODE_PROVIDER_BACKOFF_MS=450
BARCODE_PROVIDER_INTER_REQUEST_DELAY_MS=120
BARCODE_CACHE_TTL_FOUND_SECONDS=604800
BARCODE_CACHE_TTL_NOT_FOUND_SECONDS=86400
BARCODE_CACHE_TTL_ERROR_SECONDS=900
BARCODE_REVIEW_CATEGORY_PRIORITY=

OPENFOODFACTS_API_URL=https://world.openfoodfacts.org
OPENFOODFACTS_USER_AGENT=BomFilho/1.0 (contato@bomfilho.com)
COSMOS_API_URL=
COSMOS_LOOKUP_PATH_TEMPLATE=/gtins/{gtin}.json
COSMOS_API_TOKEN=
UPCITEMDB_API_URL=https://api.upcitemdb.com/prod/trial/lookup
UPCITEMDB_API_KEY=

# ============================================
# PAGBANK LEGACY (optional, keep disabled unless migration/testing)
# ============================================
PAGBANK_ENABLED=false
# sandbox | production
PAGBANK_ENV=sandbox
PAGBANK_TOKEN=
PAGBANK_PUBLIC_KEY=
PAGBANK_WEBHOOK_TOKEN=
PAGBANK_DEBUG_LOGS=false
ALLOW_PIX_MOCK=false
ALLOW_DEBIT_3DS_MOCK=false
PAGBANK_TIMEOUT_MS=15000

# ============================================
# UBER DIRECT (optional)
# ============================================
UBER_DIRECT_ENABLED=false
UBER_DIRECT_BASE_URL=https://api.uber.com/v1
UBER_DIRECT_OAUTH_URL=https://login.uber.com/oauth/v2/token
UBER_DIRECT_CUSTOMER_ID=
UBER_DIRECT_CLIENT_ID=
UBER_DIRECT_CLIENT_SECRET=
UBER_DIRECT_WEBHOOK_TOKEN=
UBER_DIRECT_TIMEOUT_MS=15000
UBER_PICKUP_NAME=BomFilho Supermercado
UBER_PICKUP_PHONE=
UBER_PICKUP_ADDRESS=

# ============================================
# OBSERVABILITY (optional)
# ============================================
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
