# [OBRIGATORIA]
# Configuracoes do banco de dados
# Formato: mysql://USUARIO:SENHA@HOST:PORT/BANCO
DATABASE_URL=mysql://root:sua_senha_aqui@localhost:3306/railway

# [OPCIONAL]
# Configuracoes do servidor
PORT=3000

# [OBRIGATORIA em producao]
# CORS (origens permitidas, separadas por virgula)
# Inclua localhost para dev e dominio da Vercel para producao.
# Opcionalmente, inclua wildcard para previews: https://*.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://SEU_FRONTEND.vercel.app

# [OPCIONAL]
# URL principal do frontend para adicionar automaticamente na allowlist de CORS
FRONTEND_APP_URL=

# [OBRIGATORIA em producao]
# Se estiver atras de proxy reverso confiavel (Render/Cloudflare/Nginx), marque true
TRUST_PROXY=false

# [OBRIGATORIA em producao]
# Cookies de sessao (HttpOnly)
# Em producao HTTPS, use true
COOKIE_SECURE=false
# strict | lax | none
# Para frontend e API em dominios diferentes (ex.: Vercel + Render), use none
COOKIE_SAME_SITE=strict
# Opcional: domínio dos cookies (ex: .seusite.com)
COOKIE_DOMAIN=

# JWT Secret (gere uma chave aleatória segura)
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_123456

# Google reCAPTCHA (opcional, recomendado para login/cadastro)
RECAPTCHA_SECRET_KEY=
# Usado apenas para respostas com score (reCAPTCHA v3)
RECAPTCHA_MIN_SCORE=0.5

# Token opcional para proteger rotas de diagnóstico locais
# Envie em x-diagnostic-token (ou Authorization: Bearer ...)
DIAGNOSTIC_TOKEN=
# Habilita acesso remoto às rotas de diagnóstico somente com DIAGNOSTIC_TOKEN
# false = apenas localhost | true = remoto permitido com token
ALLOW_REMOTE_DIAGNOSTIC=false

# ============================================
# ADMIN LOCAL (painel da loja)
# ============================================
# Usuário/senha do painel administrativo
ADMIN_USER=admin
ADMIN_PASSWORD=troque_por_uma_senha_forte

# true  = aceita admin apenas no próprio computador (127.0.0.1)
# false = desativa bloqueio por IP local (não recomendado)
ADMIN_LOCAL_ONLY=true

# ============================================
# PAGBANK (PIX)
# ============================================
# sandbox | production
PAGBANK_ENV=sandbox
# Cole aqui o token do Portal PagBank
PAGBANK_TOKEN=seu_token_pagbank
# Chave publica para criptografia de cartao no frontend (SDK PagBank)
# No Render, configure no painel de Environment sem aspas extras e sem quebras de linha inválidas.
# Exemplo: PAGBANK_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----MIIBIjANBg...IDAQAB-----END PUBLIC KEY-----
PAGBANK_PUBLIC_KEY=
# Logs detalhados da integracao PagBank (request/response com mascaramento)
# true = habilitado | false = desabilitado
PAGBANK_DEBUG_LOGS=true

# Permite fallback de PIX simulado quando PAGBANK_TOKEN falhar/ausente (apenas sandbox)
# Homologacao/produção: mantenha false para nao mascarar falhas reais
ALLOW_PIX_MOCK=false

# Permite fallback de authentication_method 3DS mock para pagamentos em debito (apenas sandbox)
# Em producao, mantenha false e envie authentication_method real obtido via fluxo 3DS
ALLOW_DEBIT_3DS_MOCK=false

# Token compartilhado para validar webhook do PagBank
# O backend envia este token na notification_url como ?token=...
# O webhook aceita token via query e tambem via header x-webhook-token
# Obrigatorio em producao: sem ele o backend falha ao iniciar
PAGBANK_WEBHOOK_TOKEN=troque_por_um_token_grande_e_aleatorio

# URL pública do seu backend (necessária para o webhook do PagBank)
# Em localhost, use um túnel (ngrok/Cloudflare Tunnel) e coloque a URL https aqui.
BASE_URL=http://localhost:3000

# ============================================
# EVOLUTION API - WHATSAPP (opcional)
# ============================================
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_da_evolution
EVOLUTION_INSTANCE=loja
# Token opcional para validar webhook da Evolution no backend
EVOLUTION_WEBHOOK_TOKEN=troque_por_um_token_grande_e_aleatorio
# Auto-resposta quando cliente mandar mensagem para o WhatsApp da loja
WHATSAPP_AUTO_REPLY_ENABLED=false
WHATSAPP_AUTO_REPLY_TEXT=Estamos com o site do Bom Filho no ar. Faca seu pedido por la.
# Opcional: evita responder repetidamente no mesmo numero em um intervalo curto
WHATSAPP_AUTO_REPLY_COOLDOWN_SECONDS=0

# Mercado Pago (teste ou produção)
MP_ACCESS_TOKEN=seu_access_token_do_mercado_pago
MP_PUBLIC_KEY=sua_public_key_do_mercado_pago
MP_WEBHOOK_URL=https://sua-url-publica.com/api/webhooks/mercadopago

