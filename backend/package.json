{
  "name": "bom-filho-backend",
  "version": "1.0.0",
  "description": "Backend API para supermercado Bom Filho",
  "main": "server.js",
  "engines": {
    "node": ">=20 <25"
  },
  "packageManager": "npm@10.9.0",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "tunnel": "npx --yes localtunnel --port 3000 --local-host localhost --host https://loca.lt",
    "enrichment:barcode:report": "node scripts/enrichment-barcode-saneamento.js --mode report",
    "enrichment:barcode:dry-run": "node scripts/enrichment-barcode-saneamento.js --mode apply",
    "enrichment:barcode:apply": "node scripts/enrichment-barcode-saneamento.js --mode apply --apply",
    "enrichment:barcode:reprocess": "node scripts/enrichment-barcode-saneamento.js --mode reprocess",
    "enrichment:barcode:manual-queue": "node scripts/enrichment-barcode-revisao-manual.js --mode export-queue",
    "enrichment:barcode:manual-import": "node scripts/enrichment-barcode-revisao-manual.js --mode import-corrections",
    "enrichment:barcode:manual-reprocess": "node scripts/enrichment-barcode-revisao-manual.js --mode reprocess-approved",
    "enrichment:barcode:dv:dry-run": "node scripts/enrichment-barcode-autoaprovar-dv.js --mode dry-run",
    "enrichment:barcode:dv:apply": "node scripts/enrichment-barcode-autoaprovar-dv.js --mode apply --apply",
    "enrichment:barcode:dv:reprocess": "node scripts/enrichment-barcode-autoaprovar-dv.js --mode reprocess",
    "enrichment:barcode:invalid-length:report": "node scripts/enrichment-barcode-invalid-length-report.js --mode report",
    "enrichment:barcode:invalid-length:dry-run": "node scripts/enrichment-barcode-invalid-length-report.js --mode report",
    "enrichment:barcode:pad-left-zero:report": "node scripts/enrichment-barcode-pad-left-zero-report.js --mode report",
    "enrichment:barcode:pad-left-zero:dry-run": "node scripts/enrichment-barcode-pad-left-zero-report.js --mode report",
    "enrichment:barcode:pad-left-zero:apply:dry-run": "node scripts/enrichment-barcode-pad-left-zero-apply.js --mode dry-run",
    "enrichment:barcode:pad-left-zero:apply:execute": "node scripts/enrichment-barcode-pad-left-zero-apply.js --mode execute",
    "enrichment:barcode:stage-closeout": "node tools/generate-enrichment-stage-closeout.js",
    "enrichment:ai:stats": "node scripts/enrich-ai-descriptions.js --mode stats",
    "enrichment:ai:dry-run": "node scripts/enrich-ai-descriptions.js --mode dry-run",
    "enrichment:ai:apply": "node scripts/enrich-ai-descriptions.js --mode apply",
    "catalogo:sync:dry-run": "node scripts/catalogo-atualizacao-massa.js --mode dry-run",
    "catalogo:sync:apply": "node scripts/catalogo-atualizacao-massa.js --mode apply --apply true",
    "catalogo:categorizar:preview": "node scripts/catalogo-categorizar-por-nome.js --mode preview",
    "catalogo:categorizar:preview:lote-higiene-limpeza": "node scripts/catalogo-categorizar-por-nome.js --mode preview --applyCategories \"Limpeza,Lavanderia,Higiene Pessoal,Descartaveis,Utilidades Domesticas\" --minApplyConfidence 0.90",
    "catalogo:categorizar:apply": "node scripts/catalogo-categorizar-por-nome.js --mode apply --apply true",
    "catalogo:categorizar:apply:sync-departamento": "node scripts/catalogo-categorizar-por-nome.js --mode apply --apply true --syncDepartamento true",
    "taxonomia:audit": "node scripts/taxonomia-classificacao-pipeline.js --mode audit",
    "taxonomia:preview": "node scripts/taxonomia-classificacao-pipeline.js --mode preview",
    "taxonomia:apply:safe": "node scripts/taxonomia-classificacao-pipeline.js --mode apply-safe --apply true",
    "taxonomia:apply:partial": "node scripts/taxonomia-classificacao-pipeline.js --mode apply-partial --apply true",
    "taxonomia:apply:full": "node scripts/taxonomia-classificacao-pipeline.js --mode apply-full --apply true",
    "taxonomia:rollback": "node scripts/taxonomia-classificacao-pipeline.js --mode rollback",
    "taxonomia:legacy:preview": "node scripts/taxonomia-classificacao-pipeline.js --mode preview --legacyRecategorizacao true",
    "taxonomia:legacy:apply:safe": "node scripts/taxonomia-classificacao-pipeline.js --mode apply-safe --legacyRecategorizacao true --apply true",
    "encoding:audit:db": "node tools/auditar-encoding-banco.js",
    "migrate": "node migrate.js",
    "migrate:dry-run": "node migrate.js --dry-run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json}\" --ignore-path .eslintignore",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit --detectOpenHandles"
  },
  "keywords": [
    "supermercado",
    "ecommerce",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "compression": "^1.8.1",
    "connect-timeout": "^1.9.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.19.1",
    "pg": "^8.16.3",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.2.0",
    "supertest": "^7.2.2"
  }
}
