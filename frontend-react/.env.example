# [OBRIGATORIA em preview/producao]
# URL publica do backend (Render)
# Exemplo: https://bomfilho.onrender.com
VITE_API_URL=https://SEU_BACKEND.onrender.com

# [OPCIONAL]
# Timeout das requisicoes HTTP em milissegundos
# Exemplo: 15000
VITE_API_TIMEOUT_MS=15000

# [OPCIONAL]
# Persistência de access token em localStorage (compatibilidade legada)
# Recomendado manter false para usar sessão baseada em cookie HttpOnly + CSRF
# Com false, garanta no backend: COOKIE_SECURE=true, COOKIE_SAME_SITE=none e CORS_ORIGINS com a URL do frontend
VITE_ENABLE_TOKEN_STORAGE=false

# [OPCIONAL]
# Google reCAPTCHA (site key)
# Exemplo: 6LcXXXXXXXXXXXXXXXXXXXXXX
VITE_RECAPTCHA_SITE_KEY=

# [OPCIONAL]
# Proteção antiabuso no checkout/pagamento
# true = frontend exige reCAPTCHA no fluxo de pedido/pagamento
VITE_RECAPTCHA_CHECKOUT_ENABLED=false

# [OBRIGATORIA para Mercado Pago]
# Chave publica do Mercado Pago para tokenizacao de cartao no frontend
# Exemplo (teste): TEST-ef5eddb3-ffb7-475b-b26e-695eeb40fd4e
# Exemplo (producao): APP_USR-xxxx
VITE_MP_PUBLIC_KEY=

# [OPCIONAL - apenas desenvolvimento]
# Alvo do proxy /api no Vite dev server
# Exemplo: http://localhost:3000
VITE_DEV_API_PROXY_TARGET=http://localhost:3000

# ============================================
# DADOS DA LOJA (opcional — todos têm defaults)
# ============================================
# Sobrescreva para personalizar identidade da loja sem alterar código
# VITE_STORE_NAME=BomFilho Supermercado
# VITE_STORE_CNPJ=09.175.211/0001-30
# VITE_STORE_CEP=68740-180
# VITE_STORE_NUMERO=70
# VITE_STORE_ENDERECO=Travessa 07 de Setembro, nº 70 - CEP 68740-180
# VITE_STORE_HORARIO=Segunda a sábado, das 07h às 22h
# VITE_STORE_HORARIO_CURTO=Segunda a sabado: 7h30 as 13h e 15h as 19h30 | Domingos e feriados: 8h as 12h30
# VITE_STORE_TEMPO_RETIRADA=20-40 min
# VITE_STORE_WHATSAPP=5591999652790
# VITE_STORE_WHATSAPP_DISPLAY=(91) 99965-2790
# VITE_STORE_WHATSAPP_URL=https://wa.me/5591999652790?text=...
# VITE_STORE_TELEFONE=+559137219780
# VITE_STORE_TELEFONE_DISPLAY=(91) 3721-9780
# VITE_STORE_LIMITE_BIKE_KM=1

# ============================================
# WEB VITALS (opcional)
# ============================================
# Habilita coleta de Core Web Vitals no console (dev) ou endpoint (prod)
# VITE_ENABLE_WEB_VITALS=true
