# BomFilho frontend environment template (Vite)
# Encoding: UTF-8
# Important: only VITE_* variables are exposed to the browser.
# Never place private tokens/secrets here.

# ============================================
# REQUIRED FOR PREVIEW/PRODUCTION
# ============================================
VITE_API_URL=https://bomfilho.onrender.com

VITE_MP_PUBLIC_KEY=TEST-ef5eddb3-ffb7-475b-b26e-695eeb40f4ed4e

# ============================================
# OPTIONAL
# ============================================
VITE_API_TIMEOUT_MS=15000
# reCAPTCHA Enterprise Score (invisible — no checkbox).
# VITE_RECAPTCHA_SITE_KEY: public key from Google Cloud reCAPTCHA Enterprise console (score type).
# Backend also needs RECAPTCHA_PROJECT_ID and RECAPTCHA_CLOUD_API_KEY for Enterprise API validation.
VITE_RECAPTCHA_SITE_KEY=6Lf7J5ssAAAAAL3pyjhP82Zfsp3FXBBcyJPhq5RE
# Enable in production to block bots on auth and checkout
VITE_RECAPTCHA_AUTH_ENABLED=true
VITE_RECAPTCHA_CHECKOUT_ENABLED=true
VITE_ENABLE_TOKEN_STORAGE=false
VITE_ENABLE_WEB_VITALS=false

# ============================================
# DEV PROXY ONLY (npm run dev)
# ============================================
VITE_DEV_API_PROXY_TARGET=http://localhost:3000

