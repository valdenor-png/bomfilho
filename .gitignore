# ============================================
# .gitignore - BOM FILHO SUPERMERCADO
# ============================================

# Dependências do Node.js
node_modules/
pnpm-lock.yaml

# Se usar npm → manter
# package-lock.json

# Se usar yarn → NÃO ignore
# yarn.lock
# Arquivos env sem prefixo de ponto
**/env

# Variáveis de ambiente (NUNCA enviar para o Git)
.env
.env.*
!.env.example
!.env*.example
frontend-react/env
*.sqlite
*.sqlite3

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Sistema operacional
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
.AppleDouble
.LSOverride
$RECYCLE.BIN/
.directory
.Trash-*

# Editores
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Build
dist/
build/
out/
.next/
.nuxt/
.cache/
temp/
tmp/

# Docs (controle fino)
docs/**
!docs/
!docs/CONTEXTO_PROJETO.md
!docs/GO_LIVE_TECNICO_CHECKLIST.md
!docs/OPERACAO_ADMIN_PEDIDOS_PAGAMENTOS.md

# Uploads
uploads/
temp-uploads/
*.tmp

# Testes
coverage/
.nyc_output/
*.test.js.snap

# Certificados
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# Config local
config.local.js
config.local.json

# Cache
.npm
.eslintcache

# Dados sensíveis
credenciais.txt
senhas.txt
tokens.txt

# Scripts (whitelist)
backend/scripts/*
!backend/scripts/enrichment-barcode-saneamento.js
!backend/scripts/enrichment-barcode-revisao-manual.js
!backend/scripts/enrichment-barcode-autoaprovar-dv.js
!backend/scripts/enrichment-barcode-invalid-length-report.js
!backend/scripts/enrichment-barcode-pad-left-zero-report.js
!backend/scripts/enrichment-barcode-pad-left-zero-apply.js
!backend/scripts/enrichment-backlog-drain.js

# Backup
backup/
*.backup

# Evitar clone dentro do repo
/bomfilho/
.vercel

# ── GSD baseline (auto-generated) ──
.gsd
*.code-workspace
__pycache__/
*.pyc
.venv/
venv/
target/
vendor/
.bg-shell/
