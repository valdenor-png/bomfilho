# BomFilho Admin — environment template (Vite)
# Only VITE_* variables are exposed to the browser.

# ============================================
# REQUIRED FOR PREVIEW/PRODUCTION
# ============================================
VITE_API_URL=https://bomfilho.onrender.com

# ============================================
# OPTIONAL
# ============================================
VITE_API_TIMEOUT_MS=15000
VITE_ENABLE_TOKEN_STORAGE=false

# ============================================
# DEV PROXY ONLY (npm run dev)
# ============================================
VITE_DEV_API_PROXY_TARGET=http://localhost:3000
