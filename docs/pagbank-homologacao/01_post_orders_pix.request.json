{
  "method": "POST",
  "url": "https://api.pagseguro.com/orders",
  "headers": {
    "Authorization": "Bearer {{PAGBANK_TOKEN}}",
    "x-idempotency-key": "{{UUID}}",
    "accept": "application/json",
    "Content-Type": "application/json"
  },
  "body": {
    "reference_id": "pedido_1234",
    "customer": {
      "name": "Cliente Teste",
      "email": "cliente@example.com",
      "tax_id": "12345678909"
    },
    "items": [
      {
        "name": "Pedido #1234 - Bom Filho Supermercado",
        "quantity": 1,
        "unit_amount": 12990
      }
    ],
    "qr_codes": [
      {
        "amount": {
          "value": 12990
        },
        "expiration_date": "2026-03-09T14:30:00.000-03:00"
      }
    ],
    "notification_urls": [
      "https://SEU_BACKEND/api/webhooks/pagbank?token={{PAGBANK_WEBHOOK_TOKEN}}"
    ]
  }
}
