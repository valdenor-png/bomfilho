# ============================================
# BomFilho Supermercado — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================

# ── Core ─────────────────────────────────────
NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://user:pass@host:port/database
BASE_URL=http://localhost:3000
FRONTEND_APP_URL=http://localhost:5173
SERVE_REACT=false
TRUST_PROXY=false

# ── Segurança / Auth ────────────────────────
JWT_SECRET=                    # mínimo 32 caracteres em produção
COOKIE_SECURE=false            # true em produção
COOKIE_SAME_SITE=strict        # strict | lax | none
COOKIE_DOMAIN=

# ── Admin ────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=           # bcrypt hash — obrigatório em produção
ADMIN_PASSWORD=                # NÃO usar em produção
ADMIN_LOCAL_ONLY=true

# ── PagBank ──────────────────────────────────
PAGBANK_TOKEN=
PAGBANK_PUBLIC_KEY=
PAGBANK_WEBHOOK_TOKEN=         # obrigatório em produção
PAGBANK_ENV=sandbox            # sandbox | production
PAGBANK_DEBUG_LOGS=false
ALLOW_PIX_MOCK=false           # NÃO pode ser true em produção
ALLOW_DEBIT_3DS_MOCK=false     # NÃO pode ser true em produção

# ── Mercado Pago ─────────────────────────────
MP_ACCESS_TOKEN=               # obrigatório para pagamentos via MP
MP_PUBLIC_KEY=                 # public key para tokenização de cartão
MP_WEBHOOK_SECRET=             # obrigatório em produção para validar webhooks

# ── reCAPTCHA ────────────────────────────────
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_CHECKOUT_ENABLED=false
RECAPTCHA_PAYMENT_ENABLED=false

# ── CORS ─────────────────────────────────────
CORS_ORIGINS=                  # origens adicionais separadas por vírgula

# ── Evolution API (WhatsApp) ─────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=loja
EVOLUTION_WEBHOOK_TOKEN=
WHATSAPP_AUTO_REPLY_ENABLED=false
WHATSAPP_AUTO_REPLY_TEXT=Estamos com o site do Bom Filho no ar. Faca seu pedido por la.
WHATSAPP_AUTO_REPLY_COOLDOWN_SECONDS=0

# ── Delivery / Frete ────────────────────────
PRECO_COMBUSTIVEL_LITRO=6.2
CEP_MERCADO=68740-180
NUMERO_MERCADO=70
LIMITE_BIKE_KM=1
TAXA_SERVICO_PERCENTUAL=3

# ── Observabilidade ─────────────────────────
METRICS_ENABLED=false
METRICS_TOKEN=
DIAGNOSTIC_TOKEN=
ALLOW_REMOTE_DIAGNOSTIC=false
SENTRY_DSN=

# ── Importação ──────────────────────────────
TAMANHO_MAXIMO_IMPORTACAO_MB=8
